generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "darwin", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String    @unique
  address   String?
  gstin     String?
  createdAt DateTime  @default(now())
  invoices  Invoice[]
}

model Material {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  hsnCode     String
  defaultRate Float
  createdAt   DateTime @default(now())
}

model Invoice {
  id              Int      @id @default(autoincrement())
  invoiceNumber   String   @unique
  date            DateTime @default(now())

  customerId      Int
  customer        Customer @relation(fields: [customerId], references: [id])
  customerName    String
  customerPhone   String
  customerAddress String?
  customerGstin   String?

  items           String

  subtotal        Float
  cgst            Float    @default(0)
  sgst            Float    @default(0)
  total           Float
  gstEnabled      Boolean  @default(true)

  vehicleNumber   String?
  ewayBill        String?
  notes           String?

  createdAt       DateTime @default(now())
}
